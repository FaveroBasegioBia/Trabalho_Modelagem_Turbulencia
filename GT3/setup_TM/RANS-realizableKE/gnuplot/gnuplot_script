set logscale x
set logscale y

set xrange [ 10000.0 : 2.00000e+06 ] 
set yrange [ 0.00100000 : 0.0100000 ]

set xlabel "Re_x" 
set ylabel "c_f" 

Re(x)=U*x/nu
cf(tau)=2*tau/(U**2)
taulam(x)=nu*U*sqrt(U/(nu*x))*0.332
white(x)=0.455/log(0.06*Re(x))**2

