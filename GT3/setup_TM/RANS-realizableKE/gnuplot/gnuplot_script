U = 5.4
nu = 1.5e-05
rho = 1.186

timestep = 2000

p   'postProcessing/surfacesDict/15000/grad(U)_wall.raw' us (Re($1)):(cf(nu*$7)) w l ti "k-omega", \
    'postProcessing/surfacesDict/15000/grad(U)_wall.raw' us (Re($1)):(cf(taulam($1))) w l ti "Laminar", \
    'postProcessing/surfacesDict/15000/grad(U)_wall.raw' us (Re($1)):(white($1)) w l ti "Turbulent", \
    'gnuplot/ercoftac_t3a_cf.dat' ti "ERCOFTAC"

