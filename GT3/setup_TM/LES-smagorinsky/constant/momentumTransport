    format      ascii;
    class       dictionary;
    object      momentumTransport;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

simulationType  LES;

LES
{
turbulence on;

//LESModel        homogeneousDynSmagorinsky;
LESModel        Smagorinsky;
