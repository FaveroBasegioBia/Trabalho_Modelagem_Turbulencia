FoamFile
{
    format      ascii;
    class       volScalarField;
    object      p;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -2 0 0 0 0];

internalField   uniform 8.5e4;

boundaryField
{
    lowerWall      
    {
        type            zeroGradient;
    }

    outlet
    {
	type            fixedValue;
        value           uniform 8.5e4;
    }

    inlet
    { 
        type    zeroGradient;
    }

    lowerSymmetry      
    {
        type            zeroGradient;
    }

    upperSymmetry      
    {
        type            zeroGradient;
    }
}

