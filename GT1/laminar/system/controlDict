FoamFile
{
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     simpleFoam;

startFrom       latestTime;
startTime       0;
stopAt          endTime;
endTime         1000;
deltaT          1;

writeControl    timeStep;
writeInterval   100;
purgeWrite      0;
writeFormat     ascii;
writePrecision  12;
writeCompression uncompressed;
timeFormat      general;
timePrecision   6;
runTimeModifiable true;

functions
{
    // Apenas a tensao na parede eh util no caso laminar
    wallShearStress1
    {
        type                wallShearStress;
        libs                ("libutilityFunctionObjects.so");
        enabled             true;
        writeControl        outputTime;
    }
}

