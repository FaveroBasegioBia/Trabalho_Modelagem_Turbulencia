FoamFile
{
    format      ascii;
    class       dictionary;
    object      sampleDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

type surfaces;
libs ("libsampling.so");

writeControl writeTime;

surfaceFormat raw;

interpolationScheme cellPoint;

// Fields to sample.
fields
(
   grad(U) U 
);

surfaces
(

   wall
   {
       type patch;
       patches  ("top");
       //interpolate false;
   }

);

