# ==============================================================================
# GRAFICO 1: COMPARACAO LAMINAR VS TURBULENTO
# ==============================================================================
set terminal pngcairo size 800,600
set output "01_radial_velocity_comparison.png"

set title 'Radial velocity at outlet' 
set xlabel 'Radius'
set ylabel 'Radial velocity' 
set grid

# AQUI: O caso turbulento usa a coluna 3 (u 1:3)
plot 'gnuplot/profile_laminar.xy' u 1:2 w lp pt 7 title 'OpenFOAM - Laminar solution', \
     'postProcessing/sampleDict0/1000/profile0_p_U_wallShearStress.xy' u 1:3 w lp pt 7 title 'OpenFOAM - Turbulent solution'

# ==============================================================================
# GRAFICO 2: VALIDACAO DO PERFIL LAMINAR
# ==============================================================================
set terminal pngcairo size 800,600
set output "02_laminar_profile_validation.png"

set title 'Laminar profile at outlet' 
set xlabel 'Radius'
set ylabel 'Radial velocity' 
set grid

plot 'gnuplot/profile_laminar.xy' u 1:2 w p pt 7 title 'OpenFOAM - Laminar solution', \
     1.9865597264*(1-x**2/(0.1)**2) title "Analytical solution"

# ==============================================================================
# GRAFICO 3: PERFIL TURBULENTO (NUMERICO VS LEI DE POTENCIA)
# ==============================================================================
set terminal pngcairo size 800,600
set output "03_turbulent_profile_power_law.png"

set title 'Turbulent profile at outlet' 
set xlabel 'r/R'
set ylabel 'u/u_{max}'
set ytics 0.1
set yrange [0:1.3]
set grid

# AQUI: Limite [0:0.0999] para não dar erro na fórmula e uso da coluna 3 (u 1:3)
plot [0:0.0999] 1.183*(1-x/0.1)**(1./6.) title "Turbulent correlation - Power law", \
     'postProcessing/sampleDict0/1000/profile0_p_U_wallShearStress.xy' u 1:3 w lp pt 7 title "OpenFOAM - Turbulent solution"

