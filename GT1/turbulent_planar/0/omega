FoamFile
{
    format      ascii;
    class       volScalarField;
    object      omega;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 -1 0 0 0 0];

internalField   uniform 7.5;

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           $internalField;
    }

    outlet
    {
        type            zeroGradient;
    }

    top
    {
	//To disable wall function - Does not get the profile
        //type            fixedValue;
        //value           uniform 1e-12;
        //value           $internalField;

	//LRN-HRN - To enable wall function - Requires less iter to get profile
        type            omegaWallFunction;
        value           uniform 10000;
        //value           $internalField;

    }

    front
    {
        type            empty;
    }
    back
    {
        type            empty;
    }
    bottom
    {
        type            symmetry;
    }
}

