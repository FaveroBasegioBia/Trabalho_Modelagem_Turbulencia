FoamFile
{
    format      ascii;
    class       dictionary;
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers
{
    p
    {

        solver          PCG;
	preconditioner 	DIC;
	tolerance	1e-8;
        relTol		0.001;

/*
        solver          GAMG;
        tolerance       1e-08;
        relTol          0.01;
        smoother        GaussSeidel;
        nPreSweeps      0;
        nPostSweeps     2;
        cacheAgglomeration true;
        nCellsInCoarsestLevel 10;
        agglomerator    faceAreaPair;
        mergeLevels     1;
*/

	minIter 	3;
    }

    "(U|k|omega|epsilon|nuTilda|zeta|q)"
    {

        //solver          PBiCG;
        solver          PBiCGStab;
        preconditioner  DILU;
        tolerance       1e-8;
        relTol          0;

/*
        solver          smoothSolver;
        smoother        GaussSeidel;
        nSweeps         2;
        tolerance       1e-08;
        relTol          0;
*/

	minIter		3;
    }
}

SIMPLE
{
    nNonOrthogonalCorrectors 2;
    consistent yes;

