FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      turbulenceProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

simulationType  RAS;

RAS
{
    // Define o modelo k-Epsilon como padrao. 
    // OBS: Se no seu caso Planar voce usou kOmegaSST, troque a palavra kEpsilon por kOmegaSST abaixo para manter a mesma fisica!
    RASModel        kEpsilon;
    
    turbulence      on;
    printCoeffs     on;
}

