FoamFile
{
    format      ascii;
    class       dictionary;
    object      sampleDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

type sets;
libs (sampling);

interpolationScheme cellPoint;

setFormat       raw;

// Fields to sample.
fields
(
    U
    p
    wallShearStress
);

sets
(
    profile0                        
    {                               
        type            polyLine;                   
        axis            distance; 

        points
        (
            ( 7.996   0   0.1 )
            ( 7.996   0.1 0.1 )
        );  
    }                                

    profile1                        
    {                               
        type            uniform;
        nPoints         1000;
        axis            distance; 

        start           ( 7.996   0   0.1 );
        end             ( 7.996   0.1 0.1 );  
    }                                                   
    
);

