FoamFile
{
    format      ascii;
    class       dictionary;
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

libs
(
    "libfieldFunctionObjects.so"
    "libutilityFunctionObjects.so"
);

application     simpleFoam;

startFrom       latestTime;

startTime       0;

stopAt          endTime;

endTime         1000;

deltaT          1;

writeControl    timeStep;

writeInterval   100;

purgeWrite      0;

writeFormat     binary;

writePrecision  12;

writeCompression uncompressed;

timeFormat      general;

timePrecision   6;

runTimeModifiable true;

functions
{

minmaxdomain_scalar
{
    type            volFieldValue;
    enabled         true;
    log             true;
    writeControl    timeStep;
    writeInterval   1;
    writeFields     false;
    writeLocation   true;
    select          all;
    operation       none;
    fields
    (
        p
        k 
        omega 
        nut 
        epsilon 
        nuTilda
    );
}

minmaxdomain_vector
{
    type            volFieldValue;
    enabled         true;
    log             true;
    writeControl    timeStep;
    writeInterval   1;
    writeFields     false;
    writeLocation   true;
    select          all;
    operation       none;
    fields
    (
        U
    );
}

mindomain_scalar
{
    $minmaxdomain_scalar
    operation       min;
}

mindomain_vector
{
    $minmaxdomain_vector
    operation       none;
}

maxdomain_scalar
{
    $minmaxdomain_scalar
    operation       max;
}

maxdomain_vector
{
    $minmaxdomain_vector
    operation       none;
}

yplus
{
    type            yPlus;
    enabled         true;
    writeControl    outputTime;
}

wallShearStress1
{
    type            wallShearStress;
    enabled         true;
    writeControl    outputTime;
}

}

