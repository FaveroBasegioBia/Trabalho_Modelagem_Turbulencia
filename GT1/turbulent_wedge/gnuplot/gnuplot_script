# ==============================================================================
# GRAFICO 1: COMPARACAO LAMINAR VS TURBULENTO (WEDGE)
# ==============================================================================
set terminal pngcairo size 800,600
set output "01_wedge_radial_velocity_comparison.png"

set title 'Radial velocity at outlet (Wedge)' 
set xlabel 'Radius'
set ylabel 'Radial velocity' 
set grid

# Usa a coluna 3 (u 1:3) para ler a velocidade Ux correta do arquivo unificado
plot 'gnuplot/profile_laminar.xy' u 1:2 w lp pt 7 title 'OpenFOAM - Laminar solution', \
     'postProcessing/sampleDict0/1000/profile1_p_U_wallShearStress.xy' u 1:3 w l lw 2 title 'OpenFOAM - Turbulent Wedge'

# ==============================================================================
# GRAFICO 2: VALIDACAO DO PERFIL LAMINAR
# ==============================================================================
set terminal pngcairo size 800,600
set output "02_wedge_laminar_profile_validation.png"

set title 'Laminar profile at outlet' 
set xlabel 'Radius'
set ylabel 'Radial velocity' 
set grid

plot 'gnuplot/profile_laminar.xy' u 1:2 w p pt 7 title 'OpenFOAM - Laminar solution', \
     1.9865597264*(1-x**2/(0.1)**2) title "Analytical solution"

# ==============================================================================
# GRAFICO 3: PERFIL TURBULENTO (NUMERICO VS LEI DE POTENCIA - WEDGE)
# ==============================================================================
set terminal pngcairo size 800,600
set output "03_wedge_turbulent_profile_power_law.png"

set title 'Turbulent profile at outlet (Wedge)' 
set xlabel 'r/R'
set ylabel 'u/u_{max}'
set grid

# Limitador [0:0.0999] adicionado para evitar o aviso de "complex-valued function"
plot [0:0.0999] 1.26117411111*(1-x/0.1)**(1./6.) title "Turbulent correlation - Power law (Wedge)", \
     'postProcessing/sampleDict0/1000/profile1_p_U_wallShearStress.xy' u 1:3 w l lw 2 title "OpenFOAM - Turbulent Wedge"

