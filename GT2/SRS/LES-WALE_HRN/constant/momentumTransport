FoamFile
{
    format      ascii;
    class       dictionary;
    object      momentumTransport;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

simulationType  LES;

LES
{
    LESModel        WALE;

    turbulence		on;
    printCoeffs		on;

//WALE coefficients
/*
    WALECoeffs
    {
        Ck                  0.094;
        Ce                  1.048;
        Cw                  0.325;
    }
*/

    delta           cubeRootVol;

    cubeRootVolCoeffs
    {
        deltaCoeff      1;
    }

}

