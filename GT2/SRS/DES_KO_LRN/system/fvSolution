FoamFile
{
    format      ascii;
    class       dictionary;
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers
{

    p
    {
        solver          PCG;
        preconditioner  DIC;
        tolerance       1e-06;
        relTol          0.01;

	minIter 	2;
    }

/*
//crazy slow at the begining
    p
    {
        solver           GAMG;
        tolerance        1e-6;
        relTol           0.01;
        smoother         GaussSeidel;
        nPreSweeps       0;
        nPostSweeps      2;
        cacheAgglomeration on;
        agglomerator     faceAreaPair;
        nCellsInCoarsestLevel 100;
        mergeLevels      1;
	minIter		 3;
    }
*/

    pFinal
    {
	$p;
        tolerance        1e-6;
	relTol		 0;
	minIter		 1;
    }

    U
    {

        //solver           smoothSolver;
        //smoother         GaussSeidel;
        //tolerance        1e-8;
        //relTol           0.0;
        //nSweeps          1;

        solver          PBiCGStab;
        preconditioner  DILU;
        tolerance       1e-08;
        relTol          0.0;
    }

    UFinal
    {
        solver          PBiCGStab;
        preconditioner  DILU;
        tolerance       1e-08;
        relTol          0;
	minIter		1;
    }

    "(k|kFinal|Oomega|omegaFinal|omega.*)"
    {

        solver          PBiCGStab;
        preconditioner  DILU;
        tolerance       1e-8;
        relTol          0;
	minIter		3;
    }

    

}

PIMPLE
{
    //momentumPredictor no;
    momentumPredictor yes;	//Smagorinsky keqn diverges with urf 1 at beggining

    consistent 	yes;

    nOuterCorrectors 1;	//1 - 2 - 20
    nCorrectors     2;
    nNonOrthogonalCorrectors 1;

    //pRefCell        0;
    //pRefValue       0;

    turbOnFinalIterOnly false;

