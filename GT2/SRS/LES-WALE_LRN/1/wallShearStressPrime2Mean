FoamFile
{
    version     2.0;
    format      binary;
    arch        "LSB;label=32;scalar=64";
    class       volSymmTensorField;
    location    "1";
    object      wallShearStressPrime2Mean;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 4 -4 0 0 0 0];

internalField   uniform (0 0 0 0 0 0);

boundaryField
{
    bottom
    {
        type            calculated;
        value           uniform (0 0 0 0 0 0);
    }
    back
    {
        type            empty;
    }
    front
    {
        type            empty;
    }
    inlet
    {
        type            calculated;
        value           uniform (0 0 0 0 0 0);
    }
    outlet
    {
        type            calculated;
        value           uniform (0 0 0 0 0 0);
    }
    top
    {
        type            calculated;
        value           uniform (0 0 0 0 0 0);
    }
    slipsurface
    {
        type            calculated;
        value           uniform (0 0 0 0 0 0);
    }
}


