FoamFile
{
    format      ascii;
    class       dictionary;
    object      fvSchemes;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

ddtSchemes
{
    //default     Euler;
    default 	backward;
    //default 	CrankNicolson 0.7;
}

gradSchemes
{
    default         Gauss linear;
    //grad(p)         Gauss linear;
    //grad(U)         Gauss linear;

    //default          cellLimited Gauss linear 1;
    //grad(p)          cellLimited Gauss linear 0.5;
    //grad(U)          cellLimited Gauss linear 1;	//Dissipative
}

divSchemes
{
    default         none;

    //div(phi,U)      Gauss linearUpwind grad(U);
    div(phi,U)      Gauss linear;
    //div(phi,U)      Gauss limitedLinearV 1;
    //div(phi,U)      Gauss upwind;

    div(phi,k)     Gauss limitedLinear 1;

    div((nuEff*dev2(T(grad(U))))) Gauss linear;
}

laplacianSchemes
{
      default         Gauss linear limited 1;
}

interpolationSchemes
{
    default         linear;
}

snGradSchemes
{
    default         limited 1;
}

wallDist
{
    method meshWave;
    //method Poisson;

    //Optional entry enabling the calculation of the normal-to-wall field
    //nRequired false;
}

