FoamFile
{
    format      ascii;
    class       volScalarField;
    object      k;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -2 0 0 0 0];

//internalField   uniform 1e-09;
internalField   uniform 0.00015;

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           $internalField;
    }

    top
    {
        type            zeroGradient;
    }

    outlet
    {
        type            zeroGradient;
    }

    slipsurface
    {
        //type            zeroGradient;
        type            slip;
    }

    bottom
    {
        //type            fixedValue;
        //value           $internalField;
        //value           uniform 1e-12;

	//To use wall functions
        //type	        skqRWallFunction;
	//value           $internalField;
     	type	        kLowReWallFunction;
        value           uniform 1e-09;
    }

    frontandback
    {
	type	empty;
    }
}

