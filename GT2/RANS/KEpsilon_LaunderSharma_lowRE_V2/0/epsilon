FoamFile
{
    format      binary;
    class       volScalarField;
    object      epsilon;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -3 0 0 0 0];

internalField   uniform 0.01;

boundaryField
{
    inlet
    {
	//This will give wrong results
        //type            fixedValue;
        //value           $internalField;

	//This is ok
        type            zeroGradient;
    }
    top
    {
        type            zeroGradient;
    }
    outlet
    {
        type            zeroGradient;
    }
    slipsurface
    {
        //type            zeroGradient;
        type            slip;
    }
    bottom
    {
        //type            epsilonWallFunction;
        //value           $internalField;
        //value           uniform 5;

        type            fixedValue;
        value           uniform 1e-8;
    }

    frontandback
    {
	type	empty;
    }
}

