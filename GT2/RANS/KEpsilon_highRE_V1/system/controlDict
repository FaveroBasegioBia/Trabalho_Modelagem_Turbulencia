FoamFile
{
    format      ascii;
    class       dictionary;
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

libs
(

);

application     simpleFoam;

startFrom       latestTime;

startTime       0;

stopAt          endTime;

endTime         2000;

deltaT          1;

writeControl    timeStep;

writeInterval   100;

purgeWrite      0;

writeFormat     ascii;

writePrecision  8;

writeCompression uncompressed;

timeFormat      general;

timePrecision   6;

runTimeModifiable true;

// ************************************************************************* //

functions
{

///////////////////////////////////////////////////////////////////////////

minmaxdomain_scalar
{
    type            volFieldValue;
    libs            (fieldFunctionObjects);

    enabled         true;
    log             true;
    
    writeControl    timeStep;
    writeInterval   1;

    writeFields     false;
    writeLocation   true;

    select          all;

    operation       none;

    fields
    (
        p 
        k 
        epsilon 
        nut
    );
}

minmaxdomain_vector
{
    type            volFieldValue;
    libs            (fieldFunctionObjects);

    enabled         true;
    log             true;
    
    writeControl    timeStep;
    writeInterval   1;

    writeFields     false;
    writeLocation   true;

    select          all;

    operation       none;

    fields
    (
        U
    );
}

mindomain_scalar
{
    $minmaxdomain_scalar
    operation       min;
}

mindomain_vector
{
    $minmaxdomain_vector
    operation       min;
}

maxdomain_scalar
{
    $minmaxdomain_scalar
    operation       max;
}

maxdomain_vector
{
    $minmaxdomain_vector
    operation       max;
}

///////////////////////////////////////////////////////////////////////////

}

