FoamFile
{
    format      ascii;
    class       dictionary;
    object      probesDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

type probes;
libs ("libsampling.so");

// Fields to be probed. runTime modifiable!
fields
(
    p
    U
    wallShearStress
);

// Locations to be probed. runTime modifiable!
probeLocations
(
    (1.95 0	0)
    (1.95 0.0000000001	0)
    (1.95 0.0000001	0)
);

